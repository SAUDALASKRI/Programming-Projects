{
  "permissions": {
    "allow": [
      "mcp__playwright",
      "Bash(npx playwright:*)",
      "Bash(claude mcp:*)",
      "Bash(winget upgrade:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(node format-hook.js:*)",
      "Bash(npx prettier:*)"
    ],
    "deny": []
  },
  "PostToolUse": [
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "node format-hook.js $FILE"
        }
      ]
    }
  ]
}